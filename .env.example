NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key

CIN7_ACCOUNT_ID=your-cin7-account-id
CIN7_API_KEY=your-cin7-api-key
CIN7_BASE_URL=https://inventory.dearsystems.com/ExternalApi/v2

# --- Sync worker only (NOT needed by the Vercel web app) ---
# Supabase personal access token (Management API) used by the CIN7 sync scripts to write public.sales.
SUPABASE_ACCESS_TOKEN=your-supabase-personal-access-token
SUPABASE_PROJECT_REF=your-project-ref

# auto-sync.mjs cadence (the per-tier hook lives here)
SYNC_INTERVAL_MINUTES=20
RECONCILE_HOURS=24
RECONCILE_DAYS=45
